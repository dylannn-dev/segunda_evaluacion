REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

OUTPUT_DIR=/app/outputs

# Tiempo maximo (segundos) que el Worker espera antes de marcar una tarea
# como 'fallido' por timeout simulado.
TASK_TIMEOUT_SECONDS=8

# Si es "0", el Worker no duerme entre pasos (util para pruebas rapidas).
SIMULAR_LATENCIA=1
